# ============================================================
# .env.example — Template des variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs réelles
# ============================================================

# Environnement applicatif
APP_ENV=local

# Ports exposés sur votre machine
FRONTEND_PORT=8080
BACKEND_PORT=3001

# Redis (le backend se connecte via le nom de service Docker)
REDIS_HOST=cache
REDIS_PORT=6379
